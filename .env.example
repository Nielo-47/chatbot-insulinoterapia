# Application Settings
# Host ports
BACKEND_PORT=8000
UI_PORT=3000

# Frontend build/runtime settings
VITE_API_URL=/api
VITE_REQUEST_TIMEOUT_MS=60000

# Legacy app port (only used with --profile legacy)
PORT=8081
# Timeout (in seconds) for RAG queries - increase if you get timeout errors
RAG_TIMEOUT=180

# KB builder options (sensible defaults for local development)
# Set to true to run the KB build on container startup (costly - uses LLM/embeddings)
RUN_KB_ON_STARTUP=false
# Force reprocess of all documents when set to true (useful for development)
RUN_KB_FORCE_REPROCESS=false


# OpenRouter (LLM completions - OpenAI-compatible)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-5.2
LLM_TEMPERATURE=0.1

# Embeddings (TEI container)
# NOTE: Do NOT include the trailing /v1 here — the application will append and normalize it.
EMBEDDING_BINDING_HOST=http://localhost:8000
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
MAX_EMBED_TOKENS=8192
# Embeddings are served by the TEI container; no local vLLM is required for embeddings.

# Database Connection Settings (point to your remote hosts if needed)
REDIS_URI=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Data Paths
RAW_DATA_DIR=data/raw
WORKING_DIR=data/processed

# Storage backends (choose available options)
KV_STORAGE=RedisKVStorage
VECTOR_STORAGE=QdrantVectorDBStorage
GRAPH_STORAGE=Neo4JStorage
