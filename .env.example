# OpenRouter (LLM completions - OpenAI-compatible)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_SITE_TITLE=

# LLM Configuration
LLM_MODEL=google/gemini-2.5-flash-lite
LLM_MODEL_FALLBACK=anthropic/claude-3-haiku
LLM_TIMEOUT_SECONDS=30
LLM_PRIMARY_RETRIES=1
LLM_TEMPERATURE=0.1
LLM_RATE_LIMIT_RETRIES=1
LLM_RATE_LIMIT_SLEEP=60
LLM_SERVER_ERROR_RETRIES=1
LLM_SERVER_ERROR_SLEEP=60

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_FALLBACK_MODEL=BAAI/bge-m3
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_PRIMARY_RETRIES=1
EMBEDDING_FALLBACK_RETRIES=0
EMBEDDING_DIM=1024
MAX_EMBED_TOKENS=8192
EMBEDDING_BINDING_HOST=https://openrouter.ai/api
EMBEDDING_API_KEY=

# RAG Query Settings
RAG_QUERY_TEMPERATURE=0.1
RAG_QUERY_MAX_TOKENS=500

# Database Connection Settings
DATABASE_URL=postgresql+psycopg://chatbot:chatbot@postgres:5432/chatbot
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Cache
CHAT_CACHE_REDIS_URL=redis://redis:6379/1
CHAT_CACHE_TTL_SECONDS=300
CHAT_CACHE_KEY_PREFIX=chat:conv
SEMANTIC_CACHE_THRESHOLD=0.9

# Graph / Vector Storage
REDIS_URI=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Storage backends
KV_STORAGE=RedisKVStorage
VECTOR_STORAGE=QdrantVectorDBStorage
GRAPH_STORAGE=Neo4JStorage

# Data Paths
WORKING_DIR=data/processed
RAW_DATA_DIR=data/raw

# KB Builder
RUN_KB_ON_STARTUP=false
RUN_KB_FORCE_REPROCESS=false
SERVICE_WAIT_TIMEOUT=120
KB_BUILD_LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
KB_BUILD_LLM_MODEL_FALLBACK=qwen/qwen3-next-80b-a3b-instruct:free

# Authentication
AUTH_PASSWORD_ITERATIONS=390000
AUTH_PASSWORD_SALT_BYTES=16

# JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Conversation
CONVERSATION_HISTORY_LIMIT=50
SUMMARIZE_MAX_MESSAGES=20
CHECKPOINTER_ENABLED=false
SUMMARIZER_TEMPERATURE=0.1
SUMMARIZER_MAX_TOKENS=300
CRITIQUE_TEMPERATURE=0.0
CRITIQUE_MAX_TOKENS=600
DEFAULT_TEMPERATURE=0.1
DEFAULT_MAX_TOKENS=800

# API
DEV=false
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173