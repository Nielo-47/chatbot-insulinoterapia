# Application Settings
PORT=8080
PYTHONUNBUFFERED=1
USE_VLLM=1  # Set to 1 to enable vLLM servers

# Database Connection Settings
REDIS_URI=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# vLLM Configuration - LLM Server
LLM_BINDING_HOST=http://localhost:8000
LLM_MODEL_NAME=meta-llama/Llama-3.2-3B-Instruct
VLLM_LLM_PORT=8000

# vLLM Configuration - Embedding Server
EMBEDDING_BINDING_HOST=http://localhost:8001
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
VLLM_EMBED_PORT=8001

# Shared vLLM Settings
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.45  # Split between two models

# Embedding dimensions (depends on model)
EMBEDDING_DIM=384  # for all-MiniLM-L6-v2
MAX_EMBED_TOKENS=512

# Hugging Face
HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# Data Paths
SOURCE_PDF=/app/data/raw/doc.pdf
WORKING_DIR=/app/data/processed

# Storage backends
KV_STORAGE=RedisKVStorage
VECTOR_STORAGE=QdrantVectorDBStorage
GRAPH_STORAGE=Neo4JStorage