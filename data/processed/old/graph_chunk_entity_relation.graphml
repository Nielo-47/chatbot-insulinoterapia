<node id="lipodistrofia">
  <data key="d0">lipodistrofia</data>
  <data key="d1">condition</data>
  <data key="d2">Lipodistrofia is a condition characterized by the hardening of fat tissue and should be avoided when applying insulin.</data>
  <data key="d3">chunk-42476b8a22397aba0ab5e7a1f60e9eb9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1767907602</data>
