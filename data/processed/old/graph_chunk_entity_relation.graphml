</node>
<node id="1925">
  <data key="d0">1925</data>
  <data key="d1">year</data>
  <data key="d2">The year 1925 marks the beginning of using urine tests at home to detect sugar in urine.</data>
  <data key="d3">chunk-1589a8affdd5757e262b758cb4998689</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1767907605</data>
