  <data key="d0">pessoas</data>
  <data key="d1">person</data>
  <data key="d2">Pessoas are individuals who can have diabetes and use various methods to monitor their blood sugar levels.</data>
  <data key="d3">chunk-1589a8affdd5757e262b758cb4998689</data>
