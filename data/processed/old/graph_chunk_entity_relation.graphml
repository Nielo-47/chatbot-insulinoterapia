<node id="caroços">
  <data key="d0">caroços</data>
  <data key="d1">condition</data>
  <data key="d2">Caroços, or lipodistrofia, are areas of hardened fat that should be avoided when applying insulin.</data>
  <data key="d3">chunk-42476b8a22397aba0ab5e7a1f60e9eb9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1767907602</data>
