  <data key="d0">Jejum</data>
  <data key="d1">category</data>
  <data key="d2">Jejum é um estado de alimentação que é comum em pessoas com diabetes.&lt;SEP&gt;Jejum refers to the state of fasting or not having eaten for a certain period, often used in medical contexts to measure blood glucose levels.</data>
  <data key="d3">chunk-e6f6de4abe268656fba04970b00cea11&lt;SEP&gt;chunk-cb55aa00a7f60f489e74950ed04d190b</data>
