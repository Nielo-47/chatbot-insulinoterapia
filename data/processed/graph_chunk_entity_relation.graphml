  <data key="d12">1768244577</data>
  <data key="d13"></data>
</edge>
<edge source="Disglicemia" target="Complicações">
  <data key="d7">1.0</data>
  <data key="d8">Complicações are the long-term consequences of frequent fluctuations in blood glucose levels, which can be prevented by maintaining a balanced blood glucose level.</data>
  <data key="d9">condition</data>
  <data key="d10">chunk-5b718276408c07c4ce95283bdfdf03de</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1768244578</data>
  <data key="d13"></data>
</edge>
<edge source="Disglicemia" target="Inflamações internas">
  <data key="d7">1.0</data>
  <data key="d8">Inflamações internas are a type of complication that can arise from frequent fluctuations in blood glucose levels, which can lead to the development of diabetes-related complications.</data>
