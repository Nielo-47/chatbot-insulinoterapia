<edge source="Disglicemia" target="Memória metabólica">
  <data key="d7">1.0</data>
  <data key="d8">Disglicemia is a condition where the blood glucose levels are not balanced, resulting in frequent fluctuations, which can lead to the development of memória metabólica.</data>
  <data key="d9">condition,system</data>
  <data key="d10">chunk-5b718276408c07c4ce95283bdfdf03de</data>
