<edge source="Sistema de defesa" target="Células do pâncreas">
  <data key="d7">1.0</data>
  <data key="d8">Sistema de defesa is the body's immune system that responds to threats and infections, which is compromised in diabetes tipo 1 due to the destruction of células do pâncreas.</data>
  <data key="d9">organ,system</data>
  <data key="d10">chunk-5b718276408c07c4ce95283bdfdf03de</data>
  <data key="d11">unknown_source</data>
